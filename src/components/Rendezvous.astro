---
---

<section id="rdv" class="py-28 xl:py-36 bg-ink" aria-labelledby="rdv-title">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">

    <!-- Numéro de section -->
    <div aria-hidden="true">
      <span
        class="font-fraunces font-light select-none leading-none text-white/[0.12]"
        style="font-size: clamp(5rem, 10vw, 12rem); letter-spacing: -0.04em;"
      >07</span>
    </div>

    <!-- Titre -->
    <h2
      id="rdv-title"
      class="font-fraunces font-semibold text-white mt-2 mb-20 lg:mb-24"
      style="font-size: clamp(2.2rem, 4vw, 3.8rem); letter-spacing: -0.02em; line-height: 1.06;"
      data-reveal
    >
      Prenons rendez-vous
    </h2>

    <!-- Deux colonnes : réservation & téléphone -->
    <div class="grid lg:grid-cols-2 gap-0 border-t border-white/10">

      <!-- Gauche : réserver en ligne -->
      <div class="py-12 lg:py-16 lg:pr-20 border-b lg:border-b-0 lg:border-r border-white/10" data-reveal>
        <p class="text-[11px] text-white/30 uppercase tracking-[0.18em] mb-8">En ligne</p>
        <a
          href="#"
          class="cta-link font-fraunces font-semibold text-[#A5C5E0]"
          style="font-size: clamp(1.8rem, 3vw, 2.8rem); letter-spacing: -0.02em; line-height: 1.1;"
        >
          Réserver en ligne
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 10h14M10 3l7 7-7 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <p class="mt-6 text-sm text-white/35 leading-relaxed max-w-xs">
          Consultation initiale disponible sous 48 h. Confirmation par e-mail immédiate.
        </p>
      </div>

      <!-- Droite : téléphone -->
      <div class="py-12 lg:py-16 lg:pl-20" data-reveal data-delay="2">
        <p class="text-[11px] text-white/30 uppercase tracking-[0.18em] mb-8">Par téléphone</p>
        <a
          href="tel:+33491234567"
          class="cta-link font-fraunces font-semibold text-white"
          style="font-size: clamp(1.8rem, 3vw, 2.8rem); letter-spacing: -0.02em; line-height: 1.1;"
          aria-label="Appeler le 04 91 23 45 67"
        >
          04&nbsp;91&nbsp;23&nbsp;45&nbsp;67
        </a>
        <p class="mt-6 text-sm text-white/35 leading-relaxed">
          Lun–Ven &nbsp;8h30 — 19h00<br />
          Samedi &nbsp;&nbsp;&nbsp;9h00 — 13h00
        </p>
      </div>
    </div>

    <!-- Adresse -->
    <div class="mt-16 pt-10 border-t border-white/10" data-reveal data-delay="3">
      <p class="text-[11px] text-white/25 uppercase tracking-[0.18em]">
        12 Cours Mirabeau · 13100 Aix-en-Provence
      </p>
    </div>

  </div>
</section>
