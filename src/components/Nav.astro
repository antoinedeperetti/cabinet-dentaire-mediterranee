---
---

<!--
  Nav : transparente en haut de page, bg-bg opaque au scroll.
  La transition est gérée via la classe CSS .is-scrolled plutôt que
  par manipulation Tailwind (plus fiable avec le moteur v4).
-->

<style>
  #nav-header {
    background-color: transparent;
    border-bottom-color: transparent;
  }
  #nav-header.is-scrolled {
    background-color: rgba(250, 250, 248, 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgba(10, 10, 10, 0.07);
    box-shadow: 0 1px 12px rgba(10, 10, 10, 0.05);
  }
</style>

<header
  id="nav-header"
  class="fixed top-0 left-0 right-0 z-50 border-b transition-all duration-500"
>
  <nav
    class="max-w-[1440px] mx-auto px-6 lg:px-16 h-[72px] flex items-center justify-between relative"
    aria-label="Navigation principale"
  >
    <!-- Logo -->
    <a
      href="#hero"
      class="relative z-10 font-fraunces text-[15px] italic font-normal text-ink tracking-tight hover:text-gold transition-colors duration-300"
      aria-label="Cabinet Dentaire Méditerranée — accueil"
    >
      Méditerranée
    </a>

    <!-- Liens desktop (centrés absolument) -->
    <ul
      class="hidden lg:flex items-center gap-10 absolute left-1/2 -translate-x-1/2"
      role="list"
    >
      {[
        { href: '#soins',   label: 'Soins' },
        { href: '#equipe',  label: 'Équipe' },
        { href: '#avis',    label: 'Avis' },
        { href: '#valeurs', label: 'Cabinet' },
      ].map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm text-ink/50 hover:text-ink transition-colors duration-300 font-medium tracking-wide"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA desktop -->
    <a
      href="#rdv"
      class="hidden lg:block cta-link text-sm font-medium text-ink relative z-10"
    >
      Prendre rendez-vous
    </a>

    <!-- Hamburger mobile -->
    <button
      id="nav-burger"
      class="lg:hidden relative z-10 p-2 -mr-2 cursor-pointer flex flex-col gap-[5px]"
      aria-label="Ouvrir le menu de navigation"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span id="bar1" class="block w-6 h-px bg-ink transition-all duration-300 origin-center"></span>
      <span id="bar2" class="block w-6 h-px bg-ink transition-all duration-300 origin-center"></span>
      <span id="bar3" class="block w-4 h-px bg-ink transition-all duration-300 origin-center"></span>
    </button>
  </nav>

  <!-- Menu mobile -->
  <div
    id="nav-mobile"
    class="hidden lg:hidden bg-bg border-t border-ink/8 px-6 py-10"
    role="navigation"
    aria-label="Menu mobile"
  >
    <ul class="flex flex-col gap-7" role="list">
      {[
        { href: '#soins',   label: 'Soins' },
        { href: '#equipe',  label: 'Équipe' },
        { href: '#avis',    label: 'Avis' },
        { href: '#valeurs', label: 'Cabinet' },
      ].map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="mobile-nav-link font-fraunces text-[2.5rem] leading-none text-ink hover:text-gold transition-colors duration-300"
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-6 border-t border-ink/10">
        <a href="#rdv" class="mobile-nav-link cta-link text-base font-medium text-ink">
          Prendre rendez-vous
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('nav-header')!;
  const burger = document.getElementById('nav-burger')!;
  const mobile = document.getElementById('nav-mobile')!;
  const bar1   = document.getElementById('bar1')!;
  const bar2   = document.getElementById('bar2')!;
  const bar3   = document.getElementById('bar3')!;

  // Transparent → opaque au scroll
  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 30);
  }, { passive: true });

  // Hamburger toggle
  let open = false;
  burger.addEventListener('click', () => {
    open = !open;
    mobile.classList.toggle('hidden', !open);
    burger.setAttribute('aria-expanded', String(open));
    if (open) {
      bar1.style.cssText = 'transform: translateY(6px) rotate(45deg)';
      bar2.style.cssText = 'opacity: 0; transform: scaleX(0)';
      bar3.style.cssText = 'transform: translateY(-6px) rotate(-45deg); width: 1.5rem';
    } else {
      bar1.style.cssText = '';
      bar2.style.cssText = '';
      bar3.style.cssText = '';
    }
  });

  // Fermeture auto sur clic lien
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      mobile.classList.add('hidden');
      burger.setAttribute('aria-expanded', 'false');
      bar1.style.cssText = '';
      bar2.style.cssText = '';
      bar3.style.cssText = '';
    });
  });
</script>
